# Copy file này thành terraform.tfvars và chỉnh lại giá trị

aws_region = "ap-southeast-1"
project    = "myapp"
env        = "dev"

# Network
vpc_cidr   = "10.0.0.0/16"
azs        = ["ap-southeast-1a", "ap-southeast-1b"]
pub_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
priv_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]

# App
app_port    = 3000
task_cpu    = 256
task_memory = 512

# Blue — production (stable)
blue_image_tag     = "v1.0.0"
blue_desired_count = 2

# Green — new version (đang test)
green_image_tag     = "v1.0.1"
green_desired_count = 1
